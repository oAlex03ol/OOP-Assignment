# =========================
# C++ & Qt CMake Gitignore
# =========================

# 1. Build Folders (你自己 cmake .. 產生的資料夾)
build/
build-*/

# 2. CMake Generated Files (預防你不小心在專案根目錄執行 cmake .)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
Makefile
CMakeLists.txt.user

# 3. Qt Autogen & 中介檔案
*_autogen/
moc_*.cpp
moc_*.h
ui_*.h
qrc_*.cpp

# 4. Compiled Objects & Executables (編譯出來的物件檔與最終執行檔)
*.o
*.obj
*.exe
*.out
HyperFS

# 5. OS & IDE Specific (作業系統與編輯器自動生成的垃圾檔)
.DS_Store
Thumbs.db
.vscode/